<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/item_container_siswa"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="2dp"
    android:layout_marginHorizontal="1dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="8dp"
    android:paddingHorizontal="4dp"
    android:background="@drawable/rectangle_68">

    <!-- No -->
    <TextView
        android:id="@+id/tv_no_siswa"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.8"
        android:gravity="center"
        android:text="1"
        android:textColor="#090909"
        android:textSize="14sp" />

    <!-- Nama Siswa -->
    <TextView
        android:id="@+id/tv_nama_siswa"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2.2"
        android:gravity="start"
        android:maxLines="1"
        android:ellipsize="end"
        android:text="Nama Siswa"
        android:textColor="#090909"
        android:textSize="14sp" />

    <!-- NISN -->
    <TextView
        android:id="@+id/tv_nisn_siswa"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2"
        android:gravity="center"
        android:maxLines="1"
        android:ellipsize="end"
        android:text="0012345678"
        android:textColor="#090909"
        android:textSize="14sp" />

    <!-- Kelas -->
    <TextView
        android:id="@+id/tv_kelas_siswa"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.2"
        android:gravity="center"
        android:text="12 RPL 1"
        android:textColor="#090909"
        android:textSize="14sp" />

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="80dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <!-- Edit Button -->
        <LinearLayout
            android:id="@+id/btn_edit_siswa"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="4dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/edit"
                app:tint="#070707" />

        </LinearLayout>

        <!-- Delete Button -->
        <LinearLayout
            android:id="@+id/btn_hapus_siswa"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="4dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/delete"
                app:tint="#F21010" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>