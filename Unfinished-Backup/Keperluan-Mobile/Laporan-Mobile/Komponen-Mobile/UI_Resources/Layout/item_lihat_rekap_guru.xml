<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/itemContainer"
    android:layout_width="match_parent"
    android:layout_height="53dp"
    android:layout_marginStart="1dp"
    android:layout_marginEnd="1dp"
    android:layout_marginBottom="8dp"
    android:background="@drawable/rectangle_68"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="8dp">

    <!-- No -->
    <TextView
        android:id="@+id/tvNomor"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.8"
        android:gravity="center"
        android:fontFamily="sans-serif"
        android:text="1"
        android:textColor="#000000"
        android:textSize="14sp" />

    <!-- Nama Guru -->
    <TextView
        android:id="@+id/tvNama"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2.5"
        android:layout_marginStart="6dp"
        android:gravity="start"
        android:maxLines="1"
        android:ellipsize="end"
        android:fontFamily="sans-serif"
        android:text="Nama Guru"
        android:textColor="#000000"
        android:textSize="14sp" />

    <!-- Telepon -->
    <TextView
        android:id="@+id/tvTelepon"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2.5"
        android:layout_marginStart="6dp"
        android:gravity="center"
        android:maxLines="1"
        android:ellipsize="end"
        android:fontFamily="sans-serif"
        android:text="086789123"
        android:textColor="#000000"
        android:textSize="14sp" />

    <!-- Mata Pelajaran -->
    <TextView
        android:id="@+id/tvMataPelajaran"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2.5"
        android:layout_marginStart="6dp"
        android:gravity="center"
        android:maxLines="1"
        android:ellipsize="end"
        android:fontFamily="sans-serif"
        android:text="Bahasa Inggris"
        android:textColor="#000000"
        android:textSize="14sp" />

    <!-- Button Lihat -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="36dp"
        android:layout_weight="1.8"
        android:layout_marginStart="6dp">

        <ImageButton
            android:id="@+id/btnLihat"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/rectangle_178"
            android:contentDescription="Lihat"
            android:scaleType="fitXY" />

        <TextView
            android:id="@+id/tvLabelLihat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:fontFamily="sans-serif"
            android:text="Lihat"
            android:textColor="#000000"
            android:textSize="15sp"
            android:textStyle="bold" />

    </FrameLayout>

</LinearLayout>